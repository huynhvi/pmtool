# Copy this file to secrets.toml and fill in real values.
# secrets.toml is gitignored and must NEVER be committed.

# ── Predefined accounts ──────────────────────────────────────────────
[accounts.Admins]
password = "Admin@41+"
role     = "admin"

[accounts.Usr]
password = "123456"
role     = "user"

# ── Anthropic API (for Issue Tracking AI mapping) ────────────────────
ANTHROPIC_API_KEY = "sk-ant-api03-..."

# ── Supabase Storage (for persistent data on Streamlit Cloud) ────────
